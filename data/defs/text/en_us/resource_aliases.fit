    legacySymbol = "IDS_MP_LANBROW_TITLE_HELP"
    textKey = "multiplayer.mp.lanbrow.title.help"
    fallbackKey = "legacy.mc2res.26076"
    text = "LAN BROWSER     In this screen, you can review the games currently running on your local area network, join an existing game, or host a new game. Games can be sorted by clicking any column heading. A selected game is white, games that can be joined are orange, and games that are not available for selection are gray."
    matchedFile = "data/defs/text/en_us/editor.fit"
    source = "mc2res_legacy_exact_text_match"
}

