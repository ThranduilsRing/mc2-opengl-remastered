ResourceTextAlias {
    resourceId = "IDS_BLURB_M5"
    textKey = "mission.blurb.m5"
    text = "Territories: Gain control of as many bases as possible before the timer runs out to win, or gain control of all bases to win instantly."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "5adf3214e0b5"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO151"
    textKey = "component.150.encyclopedia"
    text = "The Clan Extended-Range (ER) Large Laser extends the effective range of the Clan Large Laser to long distances. It occupies the same payload space and fires faster than the Inner Sphere version."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "6706193fdc7a"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO152"
    textKey = "component.151.encyclopedia"
    text = "The Clan Large Pulse Laser can maintain a higher firing rate than the standard Large Pulse Laser. As with many Clan weapons, the enchanced performance comes at a high cost."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "40208f34f0f4"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO154"
    textKey = "component.153.encyclopedia"
    text = "The Clan Pulse Laser can maintain a higher firing rate than the standard Pulse Laser. As with many Clan weapons, the enhanced performance comes at a high cost."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "56cf9638b8cf"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO153"
    textKey = "component.152.encyclopedia"
    text = "The Clan version of the most fundamental energy weapon, this Extended-Range Laser packs good punch for its size and occupies little enough payload space to mount it singly or in clusters. The high cost of the weapon makes it an indulgence for commanders with limited resources."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "d808ac382456"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO142"
    textKey = "component.141.encyclopedia"
    text = "The Extended-Range Large Laser, a variant of the Large Laser, extends its destructive force to long distances and competes with the superior ranges of Clan lasers. Payload space and damage are identical to the standard Large Laser. Heat generation, however, is significantly increased, as is purchase price."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "c9d96cfd693d"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO156"
    textKey = "component.155.encyclopedia"
    text = "The Flamer Array is a set of linked Flamer weapons typically seen on vehicles or smaller 'Mechs. Chained together into a single firing platform, the Flamer Array is capable of producing respectable damage the individual weapons could not."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "04d3462637fa"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO115"
    textKey = "component.114.encyclopedia"
    text = "The MG Array is actually several machine guns chained together to fire as a single weapon. Although usually seen on tanks, vehicles, and helicopters, the MG Array appears on 'Mech designs as well because of its low cost and negligible heat ouput."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "eed740d0830b"
}

ResourceTextAlias {
    resourceId = "IDS_NOMPLAYNOW"
    textKey = "unclassified.nomplaynow"
    text = "The MPlayNow executable was not found. Please reinstall it from the MechCommander 2 CD."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "5c3b550d8efc"
}

ResourceTextAlias {
    resourceId = "IDS_EDITOR_VOODOO3"
    textKey = "unclassified.editor.voodoo3"
    text = "The MechCommander 2 Mission Editor cannot run on a Voodoo 3 card with a desktop resolution higher than 1024x768. Desktop color depth must also be 16-bit color. Change your desktop resolution by right-clicking the desktop, clicking Properties, and then clicking the Settings tab."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "ef1db2a584c5"
}

ResourceTextAlias {
    resourceId = "IDS_BUILDING_ENCYCLO21"
    textKey = "object.building.encyclo21"
    text = "The Medium Wall is significantly tougher than the Light Wall but still less resistant to ordnance than the Heavy Wall. It is tall enough to block the line of sight of smaller 'Mechs and interfere with target acquisition."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "8b6f23d9557a"
}

ResourceTextAlias {
    resourceId = "IDS_BUILDING_ENCYCLO10"
    textKey = "object.building.encyclo10"
    text = "The Perimeter Alarm detects any enemy unit. Its shrill claxons may summon unseen defenders, and it should be disabled before it can sound. Fortunately, it is not armored and is quickly dispatched."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "260b8c227608"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO143"
    textKey = "component.142.encyclopedia"
    text = "The Pulse Laser and Large Pulse Laser fire rapid, short bursts of laser energy rather than a continuous beam. While this enables the weapon to deliver more overall damage, it also generates more heat."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "ad24dbf368ff"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO145"
    textKey = "component.144.encyclopedia"
    text = "The Pulse Laser and Large Pulse Laser fire rapid, short bursts of laser energy rather than a continuous beam. While this enables the weapon to deliver more overall damage, it also generates more heat. "
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "dc3023d84d4e"
}

ResourceTextAlias {
    resourceId = "IDS_SWAPFILE_TOO_SMALL"
    textKey = "unclassified.swapfile.too.small"
    text = "The Swapfile must be at least 250 MB to run MechCommander 2. The current Swapfile is %d MB. Increase the Swapfile size."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "8f76b4e47cad"
}

ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO11"
    textKey = "game.source.the_advantages_of_deploying_a_jump_jet_equipped_mech_should_61ef0a14"
    text = "The advantages of deploying a Jump Jet-equipped 'Mech should be considered before any mission.\n\nScout 'Mechs can acquire excellent vantage points for observing enemy installations or battle team movements by vaulting to high ground from the leeward side.\n\nHaving a jump 'Mech in any weight class can help with both dogfights in open terrain and assault/siege attacks. In dogfights, fire-support 'Mechs can grab high ground before foot-bound 'Mechs and serially destroy enemy 'Mechs. 'Mechs on the valley floor, for example, would already be engaged with the jumper's battlemates and could offer diminished defensive fire. Such a jump 'Mech can turn any face-off beneath it into a two-on-one fight with a swivel of its torso.\n\nIn a base assault or siege maneuver, jumpers can hurdle base walls and capture interior structures such as turret and gate controls. Without a jumper ï¿½Mech on the team, the others have to use prolonged barrages to \"open the door.\"\n\n\n\n"
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "61ef0a1492e4"
}

