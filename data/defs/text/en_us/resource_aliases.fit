ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO148"
    textKey = "component.147.encyclopedia"
    text = "Heavy Lasers represent the latest advancement and research in laser weapon technology. Aimed at increasing damage potential while retaining compact size, Heavy Lasers boast the highest damage-to-size ratio of any weapon. The main weakness of Heavy Lasers is their immense heat output, limiting the number of these weapons that can be carried by any 'Mech."
    source = "source_audit"
    sourceAreas = "test_scripts"
    categories = "resource_visible_candidate;runtime_visible_candidate"
    textHash = "d6646bf109ff"
}

