ResourceTextAlias {
    resourceId = "IDS_COMPENCYCLO114"
    textKey = "component.113.encyclopedia"
    text = "Clan Gauss Rifles function on the same principles as the standard Gauss Rifle, accelerating a solid slug along electromagnetic rails to high velocities. Clan engineering improvements over the standard Gauss Rifle can be seen in the power induction system and load mechanisms, resulting in a better firing rate."
    source = "source_audit"
