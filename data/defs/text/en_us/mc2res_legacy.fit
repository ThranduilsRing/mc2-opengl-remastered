}

String {
    key = "legacy.mc2res.34149"
    text = "undefined"
    legacyId = 34149
    legacySymbol = "IDS_COMPENCYCLO150"
    source = "mc2res"
    sourceKey = "component.149.encyclopedia"
    category = "placeholders"
    sourceFile = "data/defs/text/en_us/placeholders.fit"
}

String {
    key = "legacy.mc2res.34150"
    text = "The Clan Extended-Range (ER) Large Laser extends the effective range of the Clan Large Laser to long distances. It occupies the same payload space and fires faster than the Inner Sphere version."
    legacyId = 34150
    legacySymbol = "IDS_COMPENCYCLO151"
    source = "mc2res"
    sourceKey = "component.150.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34151"
    text = "The Clan Large Pulse Laser can maintain a higher firing rate than the standard Large Pulse Laser. As with many Clan weapons, the enchanced performance comes at a high cost."
    legacyId = 34151
    legacySymbol = "IDS_COMPENCYCLO152"
    source = "mc2res"
    sourceKey = "component.151.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34152"
    text = "The Clan version of the most fundamental energy weapon, this Extended-Range Laser packs good punch for its size and occupies little enough payload space to mount it singly or in clusters. The high cost of the weapon makes it an indulgence for commanders with limited resources."
    legacyId = 34152
    legacySymbol = "IDS_COMPENCYCLO153"
    source = "mc2res"
    sourceKey = "component.152.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34153"
    text = "The Clan Pulse Laser can maintain a higher firing rate than the standard Pulse Laser. As with many Clan weapons, the enhanced performance comes at a high cost."
    legacyId = 34153
    legacySymbol = "IDS_COMPENCYCLO154"
    source = "mc2res"
    sourceKey = "component.153.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34154"
    text = "The Particle Projection Cannon, or PPC, fires bolts consisting mainly of high-energy protons or ions. Unlike laser weapons, the PPC is able to deliver both kinetic and thermal energy, resulting in excellent penetration power against armor. \\\n\\\nAn impressive example of advanced Clan engineering, the Clan ER PPC is effective to long range and can maintain a higher firing rate than the standard PPC. Although prohibitively expensive, this weapon remains a favorite among elite Clan MechWarriors."
    legacyId = 34154
    legacySymbol = "IDS_COMPENCYCLO155"
    source = "mc2res"
    sourceKey = "component.154.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34155"
    text = "The Flamer Array is a set of linked Flamer weapons typically seen on vehicles or smaller 'Mechs. Chained together into a single firing platform, the Flamer Array is capable of producing respectable damage the individual weapons could not."
    legacyId = 34155
    legacySymbol = "IDS_COMPENCYCLO156"
    source = "mc2res"
    sourceKey = "component.155.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34156"
    text = "The Laser is a dependable and inexpensive weapon that can be found on any military unit, a true staple of modern warfare. Compact while still producing decent damage, even advanced 'Mech designs incorporate lasers to support more advanced weaponry.\\\n\\\n\\\n\\\n"
    legacyId = 34156
    legacySymbol = "IDS_COMPENCYCLO157"
    source = "mc2res"
    sourceKey = "component.156.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.34157"
    text = "undefined"
    legacyId = 34157
    legacySymbol = "IDS_COMPENCYCLO158"
    source = "mc2res"
    sourceKey = "component.157.encyclopedia"
    category = "placeholders"
    sourceFile = "data/defs/text/en_us/placeholders.fit"
}

