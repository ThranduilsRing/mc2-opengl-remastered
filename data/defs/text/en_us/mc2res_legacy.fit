String {
    key = "legacy.mc2res.26378"
    text = "MAP LIST     A list of all available maps for this game. Select a map to view its tactical map image. Click Accept to load the map for the current game. If the map you want does not appear in this list, make sure it is stored in the \\\\Data\\\\Missions folder where MechCommander 2 is installed on your hard drive."
    legacyId = 26378
    legacySymbol = "IDS_MP_LOAD_MAP_MAP_LIST_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.load.map.map.list.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26379"
    text = "MAP INFO     Information on the map selected in the Map List."
    legacyId = 26379
    legacySymbol = "IDS_MP_LOAD_MAP_MAP_INFO_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.load.map.map.info.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26380"
    text = "ACCEPT     Keep your current map selection and return to the previous screen."
    legacyId = 26380
    legacySymbol = "IDS_MP_LOAD_MAP_ACCEPT_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.load.map.accept.help"
    category = "editor"
    sourceFile = "data/defs/text/en_us/editor.fit"
}

String {
    key = "legacy.mc2res.26381"
    text = "CANCEL     Cancel your current map selection and return to the previous screen."
    legacyId = 26381
    legacySymbol = "IDS_MP_LOAD_MAP_CANCEL_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.load.map.cancel.help"
    category = "editor"
    sourceFile = "data/defs/text/en_us/editor.fit"
}

String {
    key = "legacy.mc2res.26382"
    text = "LOAD MAP     In this screen, you review and select a map and mission for the game."
    legacyId = 26382
    legacySymbol = "IDS_MP_LOAD_MAP_TITLE_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.load.map.title.help"
    category = "mission"
    sourceFile = "data/defs/text/en_us/mission.fit"
}

String {
    key = "legacy.mc2res.26383"
    text = "PLAYER     The name of each player currently connected to the mission and his or her unit name and insignia."
    legacyId = 26383
    legacySymbol = "IDS_MP_PARAMETERS_PLAYER_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.player.help"
    category = "mission"
    sourceFile = "data/defs/text/en_us/mission.fit"
}

String {
    key = "legacy.mc2res.26384"
    text = "TEAM     The team number each player is currently on. To change teams, click the drop-down arrow, and then select the desired team number in the list."
    legacyId = 26384
    legacySymbol = "IDS_MP_PARAMETERS_TEAM_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.team.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26385"
    text = "FACTION     The faction each player is currently playing as in a logistics game. To change factions, click the drop-down arrow, and then select the desired faction. Steiner, Davion, or Liao makes available all 'Mechs and equipment of those factions; Clan makes available only Clan 'Mechs and equipment; All (available only if the host has selected All Tech) makes available all 'Mechs (including those of the Bandits) and equipment."
    legacyId = 26385
    legacySymbol = "IDS_MP_PARAMETERS_FACTION_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.faction.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26386"
    text = "C-BILLS     The amount of C-bills available to each player, as determined by the selected map's default C-bills setting. As players join or change teams, C-bills are redistributed equally among team members. After teams are formed, the host can specify individual C-bill distribution by clicking the spin box arrows."
    legacyId = 26386
    legacySymbol = "IDS_MP_PARAMETERS_CBILLS_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.cbills.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26387"
    text = "READY     When selected, indicates that the player has accepted the host settings and is ready to play. If the host changes any mission parameters after any players have selected Ready, their check boxes are deselected and they must reselect them before the host can launch the game."
    legacyId = 26387
    legacySymbol = "IDS_MP_PARAMETERS_READY_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.ready.help"
    category = "mission"
    sourceFile = "data/defs/text/en_us/mission.fit"
}

String {
    key = "legacy.mc2res.26388"
    text = "MAP IMAGE     The tactical map of the map chosen for the current game."
    legacyId = 26388
    legacySymbol = "IDS_MP_PARAMETERS_MAP_IMAGE_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.map.image.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26389"
    text = "HOST IP ADDRESS     The host's IP address, which should be provided to players who want to connect to this game."
    legacyId = 26389
    legacySymbol = "IDS_MP_PARAMETERS_HOST_IP_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.host.ip.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26390"
    text = "USE QUICKSTART     When selected by the host, indicates that the game will bypass logistics and the 'Mechs and equipment available to the players will be those that were placed and aligned at the time of map design."
    legacyId = 26390
    legacySymbol = "IDS_MP_PARAMETERS_QUICKSTART_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.quickstart.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26391"
    text = "DROP WEIGHT     The maximum tonnage each player can have on a deployment team, as determined by the selected map's default drop weight setting. The host can change the maximum by clicking the spin box arrows."
    legacyId = 26391
    legacySymbol = "IDS_MP_PARAMETERS_DROP_WEIGHT_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.drop.weight.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26392"
    text = "C-BILLS     The amount of C-bills provided for each team, to be divided equally among team members, as determined by the selected map's default C-bills setting. The host can change the amount of C-bills by clicking the spin box arrows. Changing this amount will redistribute the C-bills each player receives, as indicated in the C-bills column."
    legacyId = 26392
    legacySymbol = "IDS_MP_PARAMETERS_CBILLSB_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.cbillsb.help"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26393"
    text = "TIME LIMIT     The maximum time limit for the mission, as determined by the selected map's default time limit setting. The host can change the maximum by clicking the spin box arrows; however, Untimed is not available if the mission type does not allow untimed missions."
    legacyId = 26393
    legacySymbol = "IDS_MP_PARAMETERS_TIME_LIMIT_HELP"
    source = "mc2res"
    sourceKey = "multiplayer.mp.parameters.time.limit.help"
    category = "mission"
    sourceFile = "data/defs/text/en_us/mission.fit"
}

String {
    key = "legacy.mc2res.26394"
    text = "RESOURCE PTS     The amount of resource points (RPs) provided for each player, as determined by the selected map's default RP setting. The host can change the amount of RPs by clicking the spin box arrows."
    legacyId = 26394
