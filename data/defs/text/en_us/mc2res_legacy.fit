}

String {
    key = "legacy.mc2res.34130"
    text = "The Clan Long-Range Missile Rack launches twice as many missile salvos as the standard LRM Rack while fitting in the same payload space. Advanced construction and lightweight materials found in many Clan weapons are evident in this device. \\\n\\\nThis weapon is found in many Clan 'Mech designs, a testament to its effectiveness."
    legacyId = 34130
    legacySymbol = "IDS_COMPENCYCLO131"
    source = "mc2res"
    sourceKey = "component.130.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

