String {
    key = "legacy.mc2res.46007"
    text = "HEAT SINK\\\nAdvantages: Raises a 'Mech's maximum heat capacity, allowing it to carry weapons that generate higher heat.\\\nDisadvantages: Consumes payload space normally used for weapons."
