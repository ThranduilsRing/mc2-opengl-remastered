    text = "LEG ACTUATOR"
    legacyId = 46005
    legacySymbol = "IDS_HELP_COMP5"
    source = "mc2res"
    sourceKey = "component.5.description"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.46006"
    text = "COCKPIT"
