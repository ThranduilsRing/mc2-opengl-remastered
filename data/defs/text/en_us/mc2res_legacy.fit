String {
    key = "legacy.mc2res.26006"
    text = "INTERNET (ZONE.COM)     Select this connection type, and then click Go to the Zone to play a MechCommander 2 multiplayer game on the MSN Gaming Zone."
    legacyId = 26006
    legacySymbol = "IDS_STRING26006"
    source = "mc2res"
    sourceKey = "ui.string26006"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26007"
    text = "GO TO THE ZONE     Click to close MechCommander 2 and point your Internet browser to the MechCommander 2 lobby on the MSN Gaming Zone. If you are not connected to the Internet, you will be prompted to connect if your computer does not automatically do so."
    legacyId = 26007
    legacySymbol = "IDS_STRING26007"
    source = "mc2res"
    sourceKey = "ui.string26007"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26008"
    text = "This connection type will close MechCommander 2 and point your Internet browser to the MechComnder 2 lobby on the MSN Gaming Zone. You must have a valid Zone account (free) to play MechCommander 2 on the Zone."
    legacyId = 26008
    legacySymbol = "IDS_STRING26008"
    source = "mc2res"
    sourceKey = "ui.string26008"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26009"
    text = "LOCAL NETWORK     Select this connection type, and then click either Go to LAN Browser or Host Game to join or host a game on your local area network."
    legacyId = 26009
    legacySymbol = "IDS_STRING26009"
    source = "mc2res"
    sourceKey = "ui.string26009"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26010"
    text = "GO TO LAN BROWSER     Click to proceed to the LAN browser, where you will find a list of games to play on your local area network."
    legacyId = 26010
    legacySymbol = "IDS_STRING26010"
    source = "mc2res"
    sourceKey = "ui.string26010"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

String {
    key = "legacy.mc2res.26011"
    text = "This connection type will let you play a MechCommander 2 multiplayer game with other people on your local area network (LAN). You must have a LAN network adapter and be connected to a LAN to use this connection type."
    legacyId = 26011
    legacySymbol = "IDS_STRING26011"
    source = "mc2res"
    sourceKey = "ui.string26011"
    category = "multiplayer"
    sourceFile = "data/defs/text/en_us/multiplayer.fit"
}

