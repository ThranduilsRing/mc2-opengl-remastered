}

String {
    key = "legacy.mc2res.26593"
    text = "GRAPHICS     Set options that control the graphics in the game. In many cases, turning off these options may improve game performance."
    legacyId = 26593
    legacySymbol = "IDS_OPTIONS_HELP_GRAPHICS_TAB"
    source = "mc2res"
    sourceKey = "ui.options.help.graphics.tab"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26594"
    text = "AUDIO     Set options that control the audio in the game."
    legacyId = 26594
    legacySymbol = "IDS_OPTIONS_HELP_AUDIO_TAB"
    source = "mc2res"
    sourceKey = "ui.options.help.audio.tab"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26595"
    text = "GAMEPLAY     Set options that control various gameplay preferences."
    legacyId = 26595
    legacySymbol = "IDS_OPTIONS_HELP_GAMEPLAY_TAB"
    source = "mc2res"
    sourceKey = "ui.options.help.gameplay.tab"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26596"
    text = "HOTKEYS     Change the actions of the hotkeys. Select the action in the Command column, type the hotkey you want for that action, and then click Accept. You can change as many hotkeys as you want before clicking Accept."
    legacyId = 26596
    legacySymbol = "IDS_OPTIONS_HELP_HOTKEYS_TAB"
    source = "mc2res"
    sourceKey = "ui.options.help.hotkeys.tab"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26597"
    text = "OPTIONS     In this screen, you can customize your graphics, audio, gameplay, and hotkeys settings."
    legacyId = 26597
    legacySymbol = "IDS_OPTIONS_HELP_OPTIONS_TITLE"
    source = "mc2res"
    sourceKey = "ui.options.help.options.title"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26598"
    text = "SHADOWS     Select to turn on shadows. Turning off shadows may dramatically improve performance."
    legacyId = 26598
    legacySymbol = "IDS_OPTIONS_HELP_SHADOWS"
    source = "mc2res"
    sourceKey = "ui.options.help.shadows"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26599"
    text = "DETAIL TEXTURES     Select to turn on the detail of terrain and water. Turning off these detail textures may dramatically improve performance."
    legacyId = 26599
    legacySymbol = "IDS_OPTIONS_HELP_DETAIL_TEXTURES"
    source = "mc2res"
    sourceKey = "ui.options.help.detail.textures"
    category = "terrain"
    sourceFile = "data/defs/text/en_us/terrain.fit"
}

String {
    key = "legacy.mc2res.26600"
    text = "HIGH OBJECT DETAIL     Select to turn on the high detail of objects. Turning off high detail may somewhat improve performance."
    legacyId = 26600
    legacySymbol = "IDS_OPTIONS_HELP_HIGH_OBJECT_DETAIL"
    source = "mc2res"
    sourceKey = "ui.options.help.high.object.detail"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26601"
    text = "HARDWARE RASTERIZER     Select to turn on hardware mode. If you have a 3D accelerator card, it is strongly recommended that you select this option, as graphics and performance will suffer in software mode. NOTE: If you change this setting, you must reboot your computer for the new setting to take effect."
    legacyId = 26601
    legacySymbol = "IDS_OPTIONS_HELP_HARDWARE_RASTERIZER"
    source = "mc2res"
    sourceKey = "ui.options.help.hardware.rasterizer"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26602"
    text = "RESOLUTION     Select the resolution of the in-mission screen. The higher the resolution, the better the graphics; however, performance may suffer on lower-end machines. Resolution cannot be changed during a mission."
    legacyId = 26602
    legacySymbol = "IDS_OPTIONS_HELP_RESOLUTION"
    source = "mc2res"
    sourceKey = "ui.options.help.resolution"
    category = "mission"
    sourceFile = "data/defs/text/en_us/mission.fit"
}

String {
    key = "legacy.mc2res.26603"
    text = "FULL SCREEN     Select to display the game in full screen mode. If this option is not selected, the game will be displayed in a window."
    legacyId = 26603
    legacySymbol = "IDS_OPTIONS_HELP_FULL_SCREEN"
    source = "mc2res"
    sourceKey = "ui.options.help.full.screen"
    category = "ui_common"
    sourceFile = "data/defs/text/en_us/ui_common.fit"
}

String {
    key = "legacy.mc2res.26604"
    text = "HARDWARE MOUSE UPDATE     Select to update your mouse every 30 frames per second, regardless of the game's frame rate. Some video cards may have trouble in this mode."
    legacyId = 26604
    legacySymbol = "IDS_OPTIONS_HELP_HARDWARE_MOUSE_UPDATE"
    source = "mc2res"
