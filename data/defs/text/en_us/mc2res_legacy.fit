String {
    key = "legacy.mc2res.28101"
    text = "MISSION 1 - DAVION ENCLAVE:  Your mission is to assault the Davion Headquarters and eliminate all Davion presence in this quadrant. Be advised that significant Clan equipment has been spotted by recon and intel operatives."
    legacyId = 28101
    legacySymbol = "IDS_MISSION_1_INFO_TEXT"
    source = "mc2res"
