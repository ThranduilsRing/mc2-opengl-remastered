String {
    key = "legacy.mc2res.26400"
    text = "RP FOR 'MECHS     When selected, awards resource points (RPs) to players every time they destroy a 'Mech or force a pilot to eject. The larger the 'Mech, the more RPs awarded. RPs will not be rewarded more than once per 'Mech unless it was salvaged in-between \"deaths.\""
    legacyId = 26400
    legacySymbol = "IDS_MP_PARAMETERS_RP_FOR_MECHS_HELP"
