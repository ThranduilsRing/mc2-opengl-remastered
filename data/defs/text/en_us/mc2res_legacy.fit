String {
    key = "legacy.mc2res.34135"
    text = "The Clan Streak SRM Pack is identical to the standard Streak SRM Pack, except it is constructed with typical high-quality Clan engineering and materials, resulting in a better firing rate.\\\n\\\n\\\n\\\n"
    legacyId = 34135
    legacySymbol = "IDS_COMPENCYCLO136"
    source = "mc2res"
    sourceKey = "component.135.encyclopedia"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

