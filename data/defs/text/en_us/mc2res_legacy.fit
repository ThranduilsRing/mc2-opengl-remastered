String {
    key = "legacy.mc2res.28930"
    text = "A redesign for the Clan Puma-class 'Mech, the Cougar has reduced acceleration compared to its predecessor but significantly increased firepower. Some opponents may mistake the Cougar for the original Puma, although few live to learn from their mistake.\\\n\\\nThe Cougar's excellent heat dissipation system allows it to mount extensive laser and missile weaponry, making this 'Mech a potent and lightweight fire support unit.\\\n\\\n\\\n"
    legacyId = 28930
    legacySymbol = "IDS_MECH_ULLER2"
    source = "mc2res"
    sourceKey = "unit.mech.uller2"
    category = "units"
    sourceFile = "data/defs/text/en_us/units.fit"
}

