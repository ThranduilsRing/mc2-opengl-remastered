String {
    key = "legacy.mc2res.46099"
    text = "LIGHT GAUSS RIFLE     Damage:  6.0     Rate of fire: 1.5     Heat:  1.0\\\nAdvantages: Good damage at long range; low  heat. \\\nDisadvantages: Large size; slow firing rate."
    legacyId = 46099
    legacySymbol = "IDS_HELP_COMP99"
    source = "mc2res"
    sourceKey = "component.99.description"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.46100"
    text = "LIGHT AUTOCANNON    Damage:  2.0    Rate of fire: 3.3    Heat:  1.0\\\nAdvantages: Rapid firing and long range, ideal for small vehicle disposal; very inexpensive; low heat.\\\nDisadvantages: Light penetration; poor performance vs. large 'Mechs."
    legacyId = 46100
    legacySymbol = "IDS_HELP_COMP100"
    source = "mc2res"
    sourceKey = "component.100.description"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.46101"
    text = "MEDIUM AUTOCANNON     Damage:  6.0     Rate of Fire: 1.8     Heat: 2.0\\\nAdvantages: Inexpensive; good damage; low heat.\\\nDisadvantage: Requires significant payload space."
    legacyId = 46101
    legacySymbol = "IDS_HELP_COMP101"
    source = "mc2res"
    sourceKey = "component.101.description"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.46102"
    text = "HEAVY AUTOCANNON     Damage: 12.0     Rate of Fire: 1.7     Heat: 7.0\\\nAdvantage: Inflicts extremely heavy damage.\\\nDisadvantages: Short range; requires significant payload space."
    legacyId = 46102
    legacySymbol = "IDS_HELP_COMP102"
    source = "mc2res"
    sourceKey = "component.102.description"
    category = "component_descriptions"
    sourceFile = "data/defs/text/en_us/component_descriptions.fit"
}

String {
    key = "legacy.mc2res.46103"
    text = "ULTRA LIGHT AUTOCANNON     Damage:  2.0     Rate of Fire: 4.5     Heat: 1.0\\\nAdvantages: Fires faster than the Light Autocannon without generating any extra heat or causing less damage.\\\nDisadvantage: Costs more than the Light Autocannon."
