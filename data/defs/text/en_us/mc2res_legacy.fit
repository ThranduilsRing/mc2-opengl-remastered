    key = "legacy.mc2res.45434"
    text = "Placeholder text: "
    legacyId = 45434
    legacySymbol = "IDS_BUILDING_ENCYCLO34"
    source = "mc2res"
    sourceKey = "object.building.encyclo34"
    category = "objects"
    sourceFile = "data/defs/text/en_us/objects.fit"
}

